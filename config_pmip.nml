!Configuration file

!__________________
! FICHIER ALPES PMIP piControl (topo absolue)
!__________________




!________________________________________________________________________________________________________________________________________________________________________________!
!_______________________________________________________Parametrization regarding inputs_________________________________________________________________________________________!


!_______________________________________________________!
!________General inputs parametrization_________________!
&global_parametrization
    lr_monthly_climate_data_availability = .true.								!Variable used to check whether monthly climate input data are available or not
    wdir_grids_generation = .true.
    lr_climate_data_x_size = 550										!Dataset extent in the x spatial dimension (x/longitude) for the selected variable
    lr_climate_data_y_size = 350										!Dataset extent in the y spatial dimension (y/latitude) for the selected variable	
    x_dim_name = 'x'
    y_dim_name = 'y'
    xy_unit = 'm'
    missing_data_error_code = -9999.99
t_start = 1
t_end = 12
lambda = 0 ! 0.00086
alpha = 0 !0.0000665417 !0.002062792888641358
beta = 31 !35 !26
delta = 12e-11 
/

!__________________________________________________________________!
!________Parametrization regarding low-resolution climate__________!

&inputs_climate_variables
    lr_climate_data_file = '/home/jbrenner/These/Applications_Paleo/GCM_data/lgm/FGOALS/LR_climate.nc'	!Path of the low resolution temperature input netCDF file (GCM's outputs). Input data must be first interpolated on the high resolution elevation grid
    lr_UVwind_file = '/home/jbrenner/These/Applications_Paleo/GCM_data/lgm/FGOALS/LR_winds.nc' !ERA5_winds_awi.nc' 
    lr_surface_temperature_id = 'tas'											!Name of the variable to be read in the input file		
    lr_precipitation_id = 'pr'
    lr_uwind_id = 'ua'
    lr_vwind_id = 'va'
/

!_______________________________________________________!
!________Parametrization regarding topography___________!

&topography
    lr_topographic_parameters = '/home/jbrenner/These/Applications_Paleo/GCM_data/lgm/FGOALS/LR_Topographic_Parameters.nc'	!Path of the low resolution elevation input netcdf file. Note that the input data must be first interpolated on the high resolution elevation grid
    lr_surface_elevation_id = 'S'											!Name of the variable to be read in the input file
    lr_topographic_insolation_id = 'topographic_daily_insolation'							
    hr_topographic_parameters = '/home/jbrenner/These/Applications_Paleo/GeoDS_Inputs_PMIP/ALPS2/HR_Topographic_Parameters_Jouvet.nc' !HR_Topographic_Parameters.nc'	!Path of the high resolution elevation input netCDF file (GCM's outputs)
    hr_surface_elevation_id = 'S'
    hr_topographic_insolation_id = 'topographic_daily_insolation'
    hr_topo_x_size = 550 												!Dataset extent in the x spatial dimension (x/longitude) for the selected variable
    hr_topo_y_size = 350												!Dataset extent in the y spatial dimension (y/latitude) for the selected variable
    hr_topo_t_size = 12													!Dataset extent in the t temporal dimension for the selected variable
/

!__________________________________________________n______________________________________________________________________________________________________________________________!
!__________________________________________________________Parametrization regarding outputs_____________________________________________________________________________________!

&downscaled_outputs
    wdir_patterns_file_path = '/home/jbrenner/These/GeoDS_Outputs'
    ds_monthly_temperature_data_file = '/home/jbrenner/These/GeoDS_Outputs/PMIP/piControl/monthly_downscaled_temperature.nc'	!Path of the downscaled climate data file generated by the algorithm
    ds_annual_temperature_data_file = '/home/jbrenner/These/GeoDS_Outputs/PMIP/piControl/annual_downscaled_temperature.nc'	
    ds_monthly_precipitation_data_file = '/home/jbrenner/These/GeoDS_Outputs/PMIP/piControl/monthly_downscaled_precipitation.nc'
    ds_annual_precipitation_data_file = '/home/jbrenner/These/GeoDS_Outputs/PMIP/piControl/annual_downscaled_precipitation.nc'
    topographic_exposure_indexes_file = '/home/jbrenner/These/GeoDS_Outputs/PMIP/piControl/topographic_exposure_indexes.nc'
    sorted_wind_directions_file = '/home/jbrenner/These/GeoDS_Outputs/PMIP/piControl/sorted_wind_directions.nc'
    ds_x_grid_lower_bound = 3791000											!High resolution topography file's lower bound in x
    ds_y_grid_lower_bound = 2201000											!High resolution topography file's lower bound in y
    spatial_resolution = 2000.0												!Size of the outputs grid points
    ds_annual_data_generation = .false.
    nbr_wdir = 30											!Number of wind directions the user wants to study
    TEI_windward_searching_dist = 70000 										!Horizontal searching distance to find WL elements influencing the topographic exposure index of grid points
    max_precipitation_increase_factor = 100.0						        	    	      	!Maximum ratio P(high_resolution)/P(low_resolution)
    broad_mountain_range_drying_effect_activator = .true.		             				!Activates/deactivates the drying effect occuring in broad mountain barriers and leading to relatively dry inner lands
    drying_effect_windward_searching_dist = 70000											
/
