!________________________________________________________________________________________________________________________________________________________________________________!
!_______________________________________________________Parametrization regarding inputs_________________________________________________________________________________________!


!_______________________________________________________!
!________General inputs parametrization_________________!
&global_parametrization
    lr_monthly_climate_data_availability = .true.								!Variable used to check whether monthly climate input data are available or not
    wdir_grids_generation = .true.
    lr_climate_data_x_size = 256										!Dataset extent in the x spatial dimension (x/longitude) for the selected variable
    lr_climate_data_y_size = 156										!Dataset extent in the y spatial dimension (y/latitude) for the selected variable	
    x_dim_name = 'longitude'
    y_dim_name = 'latitude'
    xy_unit = 'degres'
    missing_data_error_code = -9999.99
t_start = 1
t_end = 12
lambda = 0 ! 0.00086
alpha = 0 
beta = 0.0006 !16  
delta = 0.00000000001 !0.00000000005 
/

!__________________________________________________________________!
!________Parametrization regarding low-resolution climate__________!

&inputs_climate_variables
    lr_climate_data_file = '/home/jbrenner/ANDRA_GeoDS/LR_data/LR_climate.nc'	!Path of the low resolution temperature input netCDF file (GCM's outputs). Input data must be first interpolated on the high resolution elevation grid
    lr_UVwind_file = '/home/jbrenner/ANDRA_GeoDS/LR_data/LR_wind.nc' 
    lr_surface_temperature_id = 'tasAdjust'											!Name of the variable to be read in the input file		
    lr_precipitation_id = 'prAdjust'
    lr_uwind_id = 'u'
    lr_vwind_id = 'v'
/

!_______________________________________________________!
!________Parametrization regarding topography___________!

&topography
    lr_topographic_parameters = '/home/jbrenner/ANDRA_GeoDS/LR_data/LR_Topographic_Parameters.nc'	!Path of the low resolution elevation input netcdf file. Note that the input data must be first interpolated on the high resolution elevation grid
    lr_surface_elevation_id = 'S'											!Name of the variable to be read in the input file
    lr_topographic_insolation_id = 'topographic_daily_insolation'							
    hr_topographic_parameters = '/home/jbrenner/ANDRA_GeoDS/HR_data/HR_Topographic_Parameters.nc' !HR_Topographic_Parameters.nc'	!Path of the high resolution elevation input netCDF file (GCM's outputs)
    hr_surface_elevation_id = 'S'
    hr_topographic_insolation_id = 'topographic_daily_insolation'
    hr_topo_x_size = 256 												!Dataset extent in the x spatial dimension (x/longitude) for the selected variable
    hr_topo_y_size = 156												!Dataset extent in the y spatial dimension (y/latitude) for the selected variable
    hr_topo_t_size = 12													!Dataset extent in the t temporal dimension for the selected variable
/

!__________________________________________________n______________________________________________________________________________________________________________________________!
!__________________________________________________________Parametrization regarding outputs_____________________________________________________________________________________!

&downscaled_outputs
    wdir_patterns_file_path = '/home/jbrenner/These/GeoDS_Outputs'
    ds_monthly_temperature_data_file = '/home/jbrenner/These/GeoDS_Outputs/monthly_downscaled_temperature_Andra.nc'	!Path of the downscaled climate data file generated by the algorithm
    ds_annual_temperature_data_file = '/home/jbrenner/These/GeoDS_Outputs/annual_downscaled_temperature_Andra.nc'	
    ds_monthly_precipitation_data_file = '/home/jbrenner/These/GeoDS_Outputs/monthly_downscaled_precipitation_Andra.nc'
    ds_annual_precipitation_data_file = '/home/jbrenner/These/GeoDS_Outputs/annual_downscaled_precipitation_Andra.nc'
    topographic_exposure_indexes_file = '/home/jbrenner/These/GeoDS_Outputs/topographic_exposure_indexes_Andra.nc'
    sorted_wind_directions_file = '/home/jbrenner/These/GeoDS_Outputs/sorted_wind_directions_Andra.nc'
    ds_x_grid_lower_bound = -13.875											!High resolution topography file's lower bound in x
    ds_y_grid_lower_bound = 33.125 											!High resolution topography file's lower bound in y
    spatial_resolution = 0.25												!Size of the outputs grid points
    ds_annual_data_generation = .false.
    nbr_wdir = 30											!Number of wind directions the user wants to study
    TEI_windward_searching_dist = 2 										!Horizontal searching distance to find WL elements influencing the topographic exposure index of grid points
    max_precipitation_increase_factor = 100.0						        	    	      	!Maximum ratio P(high_resolution)/P(low_resolution)
    broad_mountain_range_drying_effect_activator = .true.		             				!Activates/deactivates the drying effect occuring in broad mountain barriers and leading to relatively dry inner lands
    drying_effect_windward_searching_dist = 2											
/
